    const cityMunicipalityValue = capitalizeWords(cityMunicipality.value.trim());
    const provinceValue = capitalizeWords(province.value.trim());
    const countryValue = capitalizeWords(country.value.trim());
    const zipCodeValue = zipCode.value.trim();
    const dobValue = dob.value.trim();

    let isValid = true; 

    // Id_Number Validation
    if (id_numberValue === '') {
        setError(id_number, 'ID is required');
        isValid = false;
    }else if  (id_numberValue.length !== 9) {
        setError(id_number, 'ID must be exactly 9 characters');
        isValid = false;
    }else if (!/^\d+-\d+$/.test(id_numberValue)) {
        setError(id_number, 'ID must only contain numbers and dash');
        isValid = false;  
    } else if (!/[-]/.test(id_numberValue)) {
        setError(id_number, 'ID must contain at least one dash (-)');
        isValid = false;  
    } else if (/(\.\.|__|--)/.test(id_numberValue)) {
        setError(id_number, 'ID cannot have consecutive special characters.');
        isValid = false;
    } else if (/^[_.-]/.test(id_numberValue) || /[_.-]$/.test(id_numberValue)) {
        setError(id_number, 'ID cannot start or end with a special character');
        isValid = false;
    } else if (/\s{2}/.test(id_numberValue)) {
        setError(id_number, 'ID cannot contain double spaces');
        isValid = false;
    }else {
        setSuccess(id_number);
    }

    // First Name Validation
    if (firstNameValue === '') {
        setError(firstName, 'First Name is required');
        isValid = false;
    } else if (firstNameValue.length < 2 || firstNameValue.length > 20) {
        setError(firstName, 'First Name must be between 2 and 20 characters');
        isValid = false;
    } else if (/^[A-Z\s]+$/.test(firstNameValue)) { // Check for all capital letters
        setError(firstName, 'First Name cannot be all capital letters');
        isValid = false;
    }else if (/^[_.-]/.test(firstNameValue) || /[_.-]$/.test(firstNameValue)) {
        setError(firstName, 'firstName cannot start or end with a special character');
        isValid = false;
    } else if (!/^[A-Za-z\s]+$/.test(firstNameValue)) {
        setError(firstName, 'First Name must contain only letters');
        isValid = false;
    } else if (/(.)\1{2}/.test(firstNameValue)) {
        setError(firstName, 'Consecutive identical letters are not allowed');
        isValid = false;
    } else {
        firstName.value = firstNameValue;
        setSuccess(firstName);
    }

    // Last Name Validation
    if (lastNameValue === '') {
        setError(lastName, 'Last Name is required');
        isValid = false;
    } else if (lastNameValue.length < 2 || lastNameValue.length > 15) {
        setError(lastName, 'Last Name must be between 2 and 15 characters');
        isValid = false;
    } else if (/^[A-Z\s]+$/.test(lastNameValue)) { // Check for all capital letters
        setError(lastName, 'Last Name cannot be all capital letters');
        isValid = false;
    } else if (!/^[A-Za-z\s]+$/.test(lastNameValue)) {
        setError(lastName, 'Last Name must contain only letters');
        isValid = false;
    } else if (/(.)\1{2}/.test(lastNameValue)) {
        setError(lastName, 'Three consecutive identical letters are not allowed');
        isValid = false;
    } else {
        lastName.value = lastNameValue;
        setSuccess(lastName);
    }

    // Middle Name Validation
    if (middleNameValue !== '' && (middleNameValue.length <= 1 || middleNameValue.length >= 15)) {
        setError(middleName, 'Middle Name must be between 1 and 15 characters');
        isValid = false;
    } else if (/^[A-Z\s]+$/.test(middleNameValue)) { // Check for all capital letters
        setError(middleName, 'Middle Name cannot be all capital letters');
        isValid = false;
    } else if (middleNameValue !== '' && !/^[A-Za-z\s]+$/.test(middleNameValue)) {
        setError(middleName, 'Middle Name must contain only letters');
        isValid = false;
    } else if (middleNameValue !== '' && /(.)\1{2}/.test(middleNameValue)) {
        setError(middleName, 'Consecutive identical letters are not allowed');
        isValid = false;
    } else {
        middleName.value = middleNameValue;
        setSuccess(middleName);
    }

    // Extension name Validation
    if (extensionNameValue !== '') {
        const capitalizedValue = extensionNameValue
            .toLowerCase()
            .replace(/^(jr|sr)$/i, (match) => match.charAt(0).toUpperCase() + match.slice(1)) 
            .replace(/^[ivxlcdm]+$/, (match) => match.toUpperCase()); 
        extensionName.value = capitalizedValue;

        if (capitalizedValue.length < 1 || capitalizedValue.length > 3) {
            setError(extensionName, 'Extension Name must be between 1 and 3 characters');
            isValid = false;
        }
        else if (/^(Jr|Sr)$/.test(capitalizedValue)) {
            setSuccess(extensionName);
        }
        else if (/^[IVXLCDM]+$/.test(capitalizedValue)) {
            setSuccess(extensionName); 
        }
        else {
            setError(extensionName, 'Extension Name must be "Jr", "Sr", or a valid Roman numeral in uppercase (e.g., I, IV, X)');
            isValid = false;
        }
    } else {
        setSuccess(extensionName);
    }


    // Sex Validation
    if (sexValue === '') {
        setError(sex, 'Sex is required');
        isValid = false;
    } else {
        setSuccess(sex);
    }

    // contact Validation
    if (contactValue === '') {
        setError(contact, 'Contact is required');
        isValid = false;
    } else if (!/^\d+$/.test(contactValue)) {
