        setError(password2, 'Passwords do not match');
        isValid = false;
    } else {
        setSuccess(password1);
        setSuccess(password2);
    }


   // Purok Validation
   if (purokValue !== '') {
    const capitalizedValue = purokValue
        .split(/\s+/) 
        .filter(word => word.trim() !== '') 
        .map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
