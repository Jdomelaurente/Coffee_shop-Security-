        isValid = false;
    } else if (purokValue.length < 1 || purokValue.length > 20) {
        setError(purok, 'Purok must be between 1 and 20 characters');
        isValid = false;
    } else {
        purok.value = capitalizedValue;
        setSuccess(purok);
    }
} else {
    setError(purok, 'Purok is required');
    isValid = false;
}


    // barangay Validation
    if (barangayValue !== '') {
        const capitalizedValue = barangayValue
            .split(/\s+/) // Split on one or more spaces
            .filter(word => word.trim() !== '') // Remove extra empty strings from spaces
            .map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
            .join(' '); // Join with a single space
        
        // Check if the formatted value is valid
        if (!/^[A-Za-z][A-Za-z0-9-]*(?: [A-Za-z][A-Za-z0-9-]*)*$/.test(capitalizedValue)) {
            // Check if the value contains special characters other than dash
            if (/[^A-Za-z0-9 -]/.test(capitalizedValue)) {
                setError(barangay, 'barangay cannot contain other special characters only dash');
            } else {
                setError(barangay, 'barangay cannot start with a dash or number');
            }
            isValid = false;
        } else if (barangayValue.length < 2 || barangayValue.length > 20) {
            setError(barangay, 'barangay must be between 2 and 20 characters');
            isValid = false;
        } else {
            barangay.value = capitalizedValue; // Apply the formatted value back to the field
            setSuccess(barangay);
        }
    } else {
        setError(barangay, 'barangay is required');
        isValid = false;
    }


    // city/Municipality Validation
    if (cityMunicipalityValue !== '') {
        const capitalizedValue = cityMunicipalityValue
            .split(/\s+/) // Split on one or more spaces
            .filter(word => word.trim() !== '') // Remove extra empty strings from spaces
            .map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
            .join(' '); // Join with a single space
        
        // Check if the formatted value is valid
        if (!/^[A-Za-z][A-Za-z0-9-]*(?: [A-Za-z][A-Za-z0-9-]*)*$/.test(capitalizedValue)) {
            // Check if the value contains special characters other than dash
            if (/[^A-Za-z0-9 -]/.test(capitalizedValue)) {
                setError(cityMunicipality, 'city/Municipality cannot contain other special characters only dash');
            } else {
                setError(cityMunicipality, 'city/Municipality cannot start with a dash or number');
            }
            isValid = false;
        } else if (cityMunicipalityValue.length < 2 || cityMunicipalityValue.length > 20) {
            setError(cityMunicipality, 'city/Municipality must be between 2 and 20 characters');
            isValid = false;
        } else {
            cityMunicipality.value = capitalizedValue; // Apply the formatted value back to the field
            setSuccess(cityMunicipality);
        }
    } else {
        setError(cityMunicipality, 'city/Municipality is required');
        isValid = false;
    }

    // province Validation
    if (provinceValue !== '') {
        const capitalizedValue = provinceValue
            .split(/\s+/) // Split on one or more spaces
            .filter(word => word.trim() !== '') // Remove extra empty strings from spaces
            .map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
            .join(' '); // Join with a single space
        
        // Check if the formatted value is valid
        if (!/^[A-Za-z][A-Za-z0-9-]*(?: [A-Za-z][A-Za-z0-9-]*)*$/.test(capitalizedValue)) {
            // Check if the value contains special characters other than dash
            if (/[^A-Za-z0-9 -]/.test(capitalizedValue)) {
                setError(province,  'province cannot contain other special characters only dash');
            } else {
                setError(province, 'province cannot start with a dash or number');
            }
            isValid = false;
        } else if (provinceValue.length < 2 || provinceValue.length > 20) {
            setError(province, 'province must be between 2 and 20 characters');
            isValid = false;
        } else {
            province.value = capitalizedValue; // Apply the formatted value back to the field
            setSuccess(province);
        }
    } else {
        setError(province, 'province is required');
        isValid = false;
    }

    // country Validation
    if (countryValue !== '') {
        const capitalizedValue = countryValue
            .split(/\s+/) // Split on one or more spaces
            .filter(word => word.trim() !== '') // Remove extra empty strings from spaces
            .map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
            .join(' '); // Join with a single space
        
        // Check if the formatted value is valid
        if (!/^[A-Za-z][A-Za-z0-9-]*(?: [A-Za-z][A-Za-z0-9-]*)*$/.test(capitalizedValue)) {
            // Check if the value contains special characters other than dash
            if (/[^A-Za-z0-9 -]/.test(capitalizedValue)) {
                setError(country,  'country cannot contain other special characters only dash');
            } else {
                setError(country, 'country cannot start with a dash or number');
            }
            isValid = false;
        } else if (countryValue.length < 2 || countryValue.length > 20) {
            setError(country, 'country must be between 2 and 20 characters');
            isValid = false;
        } else {
            country.value = capitalizedValue; // Apply the formatted value back to the field
            setSuccess(country);
        }
    } else {
        setError(country, 'country is required');
        isValid = false;
    }

    // Zip Code Validation
    if (zipCodeValue === '') {
        setError(zipCode, 'Zip Code is required');
        isValid = false;
    } else if (!/^\d{4}$/.test(zipCodeValue)) {
        setError(zipCode, 'Zip Code must be 4 digits and Only Numbers');
        isValid = false;
    } else {
        setSuccess(zipCode);
    }
    

    if (dobValue === '') {
        setError(dob, 'Date of Birth     is required');
        isValid = false;
    } else {
        setSuccess(dob);
    }

    return isValid;
};
function updateFromDOB() {
    const dob = document.getElementById("dob").value;
    const ageField = document.getElementById("age");
    const dobError = document.getElementById("dobError");

    if (dob) {
        const dobDate = new Date(dob);
        const today = new Date();
        let age = today.getFullYear() - dobDate.getFullYear();
        const monthDiff = today.getMonth() - dobDate.getMonth();

        if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < dobDate.getDate())) {
            age--;
        }

        if (age >= 18) {
            ageField.value = age;
            dobError.textContent = "";
        } else {
            ageField.value = "";
            dobError.textContent = "You must be 18 years old or above.";
        }
    } else {
        ageField.value = "";
        dobError.textContent = "";
    }
}

