        setSuccess(contact);
    }
    
    

    // Email Validation
    if (emailValue === '') {
        setError(email, 'Email is required');
        isValid = false;
    } else if (!/^\S+@\S+\.\S+$/.test(emailValue)) {
        setError(email, 'Email is not valid');
        isValid = false;
    } else {
